generator client {
    provider  = "prisma-client-py"
    interface = "asyncio"
}

datasource db {
    provider = "mongodb"
    url      = env("URL")
}

model User {
    id         String @id @map("_id")
    banana     Int    @default(0)
    monkey     Int    @default(0)
    reputation Int    @default(0)
}
