generator client {
    provider  = "prisma-client-py"
    interface = "asyncio"
}

datasource db {
    provider = "mongodb"
    url      = env("URL")
}

model User {
    id String @id @map("_id")

    x Int @default(0)
    y Int @default(0)

    reputation Int @default(0)

    item Int @default(0)
}
