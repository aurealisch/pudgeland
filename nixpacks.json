{
  "providers": [],
  "buildImage": "ghcr.io/railwayapp/nixpacks:ubuntu-1689638612",
  "variables": {
    "NIXPACKS_METADATA": "python",
    "PYTHONUNBUFFERED": "1"
  },
  "phases": {
    "build": {
      "dependsOn": ["install"],
      "cmds": ["prisma generate"]
    },
    "install": {
      "dependsOn": ["setup"],
      "cmds": [
        "python -m venv --copies /opt/venv && . /opt/venv/bin/activate && PIPENV_VENV_IN_PROJECT=1 pipenv install --deploy"
      ],
      "cacheDirectories": ["/root/.cache/pip"],
      "paths": ["/opt/venv/bin"]
    },
    "setup": {
      "nixPkgs": ["python311", "pipenv", "gcc"],
      "nixLibs": ["zlib", "stdenv.cc.cc.lib"],
      "nixOverlays": [],
      "nixpkgsArchive": "293a28df6d7ff3dec1e61e37cc4ee6e6c0fb0847"
    }
  },
  "start": {
    "cmds": ["python -OO -m bot"]
  }
}
